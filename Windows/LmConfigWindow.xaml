<Window x:Class="SqlForgeWpf.Windows.LmConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LM Studio Settings" Width="400" SizeToContent="Height"
        Background="{DynamicResource BgWindow}" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Loaded="Window_Loaded">

    <StackPanel Margin="20,20,20,30">
        <TextBlock Text="SERVER CONNECTION" Foreground="{DynamicResource AccentPrimary}" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

        <Grid Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="HOST / IP ADDRESS" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtHost" Text="localhost"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="PORT" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtPort" Text="1234"/>
            </StackPanel>
        </Grid>

        <TextBlock Text="API ENDPOINT" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="TxtEndpoint" Text="/v1"/>

        <Button x:Name="BtnSaveAndFetch" Content="💾 SAVE SETTINGS &amp; FETCH MODELS" Style="{StaticResource SecondaryButton}" Margin="0,0,0,25" Click="BtnSaveAndFetch_Click"/>

        <Border Height="1" Background="{DynamicResource BorderInput}" Margin="0,0,0,25"/>

        <TextBlock Text="AVAILABLE MODELS" Style="{StaticResource LabelStyle}"/>
        <ComboBox x:Name="CmbModels"/>

        <ProgressBar x:Name="LmLoadingBar" Height="3" Margin="0,0,0,15" Background="Transparent" Foreground="{DynamicResource AccentPrimary}" BorderThickness="0" IsIndeterminate="True" Visibility="Collapsed"/>

        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BtnLoad" Content="LOAD MODEL" Grid.Column="0" Click="BtnLoad_Click"/>
            <Button x:Name="BtnUnload" Content="UNLOAD ALL" Grid.Column="2" Style="{StaticResource DangerButton}" Click="BtnUnload_Click"/>
        </Grid>

        <TextBlock Text="CURRENTLY ACTIVE:" Style="{StaticResource LabelStyle}"/>
        <TextBlock x:Name="TxtActiveModel" Text="[None]" Foreground="{DynamicResource SuccessColor}" FontSize="14" FontWeight="Bold"/>
    </StackPanel>
</Window>