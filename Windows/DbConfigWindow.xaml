<Window x:Class="SqlForgeWpf.Windows.DbConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Database Connection Setup" Width="400" SizeToContent="Height"
        Background="{DynamicResource BgWindow}" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Loaded="Window_Loaded">

    <StackPanel Margin="20,20,20,30">
        <TextBlock Text="DATABASE PROFILES" Foreground="{DynamicResource AccentPrimary}" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="CmbProfiles" DisplayMemberPath="ProfileName" SelectionChanged="CmbProfiles_SelectionChanged" Margin="0,0,10,0"/>
            <Button Grid.Column="1" Content="🗑️" Style="{StaticResource DangerButton}" ToolTip="Delete Profile" Click="BtnDeleteProfile_Click" Width="40"/>
        </Grid>

        <TextBlock Text="PROFILE NAME" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="TxtProfileName" Text="New Profile"/>

        <TextBlock Text="DATABASE ENGINE" Style="{StaticResource LabelStyle}"/>
        <ComboBox x:Name="CmbDbType">
            <ComboBoxItem Content="PostgreSQL" IsSelected="True"/>
            <ComboBoxItem Content="MySQL"/>
            <ComboBoxItem Content="SQLite"/>
            <ComboBoxItem Content="Oracle"/>
        </ComboBox>

        <TextBlock Text="HOST / DATASOURCE" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="TxtHost"/>

        <TextBlock Text="PORT" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="TxtPort" Text="5432"/>

        <TextBlock Text="DATABASE NAME" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="TxtDbName"/>

        <TextBlock Text="USERNAME" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="TxtUser"/>

        <TextBlock Text="PASSWORD" Style="{StaticResource LabelStyle}"/>
        <PasswordBox x:Name="TxtPass"/>

        <Grid Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Content="SAVE PROFILE" Grid.Column="0" Style="{StaticResource SecondaryButton}" Click="BtnSaveProfile_Click"/>
            <Button Content="CONNECT" Grid.Column="2" Click="BtnConnect_Click"/>
        </Grid>
    </StackPanel>
</Window>