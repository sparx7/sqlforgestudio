<Window x:Class="SqlForgeWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SQL Forge | Multi-Engine IDE" Height="850" Width="1200"
        Background="{DynamicResource BgWindow}" FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen" WindowState="Maximized" Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{DynamicResource BgPanel}" BorderBrush="{DynamicResource BorderInput}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="SQL FORGE STUDIO" Foreground="{DynamicResource AccentPrimary}" FontSize="18" FontWeight="Black"/>
                    <Border Background="{DynamicResource BgInput}" CornerRadius="4" Padding="8,2" Margin="20,0,0,0">
                        <TextBlock x:Name="TxtQueryCount" Text="QUERIES: 0" Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="30,0,0,0" VerticalAlignment="Center">
                        <Ellipse x:Name="LedAiStatus" Width="10" Height="10" Fill="{DynamicResource DangerColor}" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TxtAiStatus" Text="AI DISCONNECTED" Foreground="{DynamicResource TextMuted}" FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="ℹ️ ABOUT" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Click="BtnAbout_Click"/>

                    <Button Content="🌓 THEME" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Click="BtnThemeToggle_Click"/>
                    <Button Content="⚙️ DB CONFIG" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Click="BtnOpenDbConfig_Click"/>
                    <Button Content="⚙️ LM CONFIG" Style="{StaticResource SecondaryButton}" Click="BtnOpenLmConfig_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource BgPanel}" CornerRadius="8" Padding="15" Margin="0,0,20,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                            <Ellipse x:Name="LedDbStatus" Width="12" Height="12" Fill="{DynamicResource DangerColor}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="DATABASE STRUCTURE" Foreground="{DynamicResource TextMuted}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Button x:Name="BtnRefreshSchema" Grid.Column="1" Content="🔄" FontSize="14" ToolTip="Force Refresh Schema" 
                                Style="{StaticResource SecondaryButton}" Width="30" Height="30" Padding="0" 
                                Click="BtnRefreshSchema_Click"/>
                    </Grid>

                    <TreeView x:Name="DbTreeView" Grid.Row="1" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Hidden">
                        <TreeView.Resources>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Margin" Value="0,4,0,4"/>
                            </Style>
                        </TreeView.Resources>
                    </TreeView>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource BgPanel}" CornerRadius="8" Margin="0,0,0,15">
                    <ScrollViewer x:Name="ChatScroll" Padding="20" VerticalScrollBarVisibility="Hidden">
                        <StackPanel x:Name="ChatHistoryPanel"/>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ProgressBar x:Name="AiLoadingBar" Grid.Row="0" Height="3" Margin="0,0,0,10" Background="Transparent" Foreground="{DynamicResource AccentPrimary}" BorderThickness="0" IsIndeterminate="True" Visibility="Collapsed"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="TxtChatInput" Grid.Column="0" Margin="0,0,15,0" Height="50" VerticalContentAlignment="Center" KeyDown="TxtChatInput_KeyDown"/>

                        <Button x:Name="BtnSend" Grid.Column="1" Width="60" Height="50" Margin="0,0,10,0" Click="BtnSend_Click">
                            <TextBlock Text="➤" FontSize="24" Foreground="White" Margin="4,0,0,0"/>
                        </Button>

                        <Button x:Name="BtnClearChat" Grid.Column="2" Width="50" Height="50" Content="🧹" FontSize="20" ToolTip="Clear Chat History" Style="{StaticResource SecondaryButton}" Click="BtnClearChat_Click"/>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource BgInput}" BorderBrush="{DynamicResource BorderInput}" BorderThickness="0,1,0,0" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="SYSTEM LOGS" Foreground="{DynamicResource TextMuted}" FontWeight="Bold" FontSize="11" Margin="0,0,0,10"/>

                <ScrollViewer Grid.Row="1" x:Name="LogScroll" VerticalScrollBarVisibility="Hidden">
                    <StackPanel x:Name="LogPanel"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>